{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/register-provider.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "cd ${CLAUDE_PLUGIN_ROOT} && python3 -m cli.main --format text prime",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd ${CLAUDE_PLUGIN_ROOT} && python3 -m cli.main --format text prime",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
